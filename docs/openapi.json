{
  "openapi": "3.0.3",
  "info": {
    "title": "Gaskuy Roadtrip API Documentation",
    "version": "1.0.0",
    "description": "Backend API untuk Gaskuy Roadtrip — platform POI, info jalan, dan perlengkapan roadtrip untuk roadtripper Indonesia.\n\n## Architecture\nFrontend → API Routes (/api/*) → Supabase (Private)\n\n**Base URL:** `/api`\n\n## Authentication\n- **Public**: GET endpoints (spots, products, routes, POI)\n- **Admin**: All CRUD operations (requires session cookie)",
    "contact": {
      "email": "support@gaskuy.id",
      "url": "https://gaskuy-roadtrip.vercel.app"
    }
  },
  "servers": [
    {
      "url": "/api",
      "description": "Production API"
    },
    {
      "url": "http://localhost:3000/api",
      "description": "Local Development"
    }
  ],
  "paths": {
    "/auth/signin": {
      "post": {
        "tags": ["Auth"],
        "summary": "Sign in with email and password",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string", "minLength": 6 }
                }
              },
              "example": {
                "email": "admin@gaskuy.id",
                "password": "securepassword123"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/APIError" }
              }
            }
          }
        }
      }
    },
    "/auth/signout": {
      "post": {
        "tags": ["Auth"],
        "summary": "Sign out current session",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": {
            "description": "Signed out",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/session": {
      "get": {
        "tags": ["Auth"],
        "summary": "Get current session and user profile",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": {
            "description": "Current session",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "user": { "$ref": "#/components/schemas/UserProfile" },
                    "session": {
                      "type": "object",
                      "properties": {
                        "access_token": { "type": "string" },
                        "expires_at": { "type": "integer" }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": { "description": "No active session" }
        }
      }
    },
    "/spots": {
      "get": {
        "tags": ["Spots"],
        "summary": "List all spots with optional filters",
        "security": [],
        "parameters": [
          { "name": "category", "in": "query", "schema": { "type": "string" } },
          { "name": "region", "in": "query", "schema": { "type": "string" } },
          { "name": "province", "in": "query", "schema": { "type": "string" } },
          { "name": "search", "in": "query", "schema": { "type": "string" } },
          { "name": "featured", "in": "query", "schema": { "type": "boolean" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20 } },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 } }
        ],
        "responses": {
          "200": {
            "description": "List of spots",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "type": "array", "items": { "$ref": "#/components/schemas/Spot" } },
                    "pagination": { "$ref": "#/components/schemas/Pagination" }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Spots"],
        "summary": "Create a new spot",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateSpotInput" }
            }
          }
        },
        "responses": {
          "201": { "description": "Spot created" },
          "400": { "description": "Validation error" },
          "401": { "description": "Unauthorized" },
          "403": { "description": "Forbidden" }
        }
      }
    },
    "/spots/{slug}": {
      "get": {
        "tags": ["Spots"],
        "summary": "Get spot by slug",
        "security": [],
        "parameters": [
          { "name": "slug", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Spot details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "$ref": "#/components/schemas/Spot" }
                  }
                }
              }
            }
          },
          "404": { "description": "Spot not found" }
        }
      },
      "put": {
        "tags": ["Spots"],
        "summary": "Update spot",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          { "name": "slug", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateSpotInput" }
            }
          }
        },
        "responses": {
          "200": { "description": "Spot updated" },
          "404": { "description": "Spot not found" }
        }
      },
      "delete": {
        "tags": ["Spots"],
        "summary": "Delete spot",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          { "name": "slug", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Spot deleted" },
          "404": { "description": "Spot not found" }
        }
      }
    },
    "/spots/{slug}/view": {
      "post": {
        "tags": ["Spots"],
        "summary": "Increment spot view count",
        "security": [],
        "parameters": [
          { "name": "slug", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "View count incremented" }
        }
      }
    },
    "/products": {
      "get": {
        "tags": ["Products"],
        "summary": "List all products",
        "security": [],
        "parameters": [
          { "name": "category", "in": "query", "schema": { "type": "string" } },
          { "name": "search", "in": "query", "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20 } },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 } }
        ],
        "responses": {
          "200": {
            "description": "List of products",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "type": "array", "items": { "$ref": "#/components/schemas/Product" } },
                    "pagination": { "$ref": "#/components/schemas/Pagination" }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Products"],
        "summary": "Create a product",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateProductInput" }
            }
          }
        },
        "responses": {
          "201": { "description": "Product created" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/products/{id}": {
      "put": {
        "tags": ["Products"],
        "summary": "Update product",
        "security": [{ "cookieAuth": [] }]
      },
      "delete": {
        "tags": ["Products"],
        "summary": "Delete product",
        "security": [{ "cookieAuth": [] }]
      }
    },
    "/poi": {
      "get": {
        "tags": ["POI"],
        "summary": "List all Points of Interest",
        "security": [],
        "responses": {
          "200": {
            "description": "List of POI",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "type": "array", "items": { "$ref": "#/components/schemas/POI" } }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["POI"],
        "summary": "Create POI",
        "security": [{ "cookieAuth": [] }]
      }
    },
    "/routes": {
      "get": {
        "tags": ["Routes"],
        "summary": "List all routes",
        "security": [],
        "responses": {
          "200": {
            "description": "List of routes",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "type": "array", "items": { "$ref": "#/components/schemas/Route" } }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Routes"],
        "summary": "Create route",
        "security": [{ "cookieAuth": [] }]
      }
    },
    "/routes/{slug}": {
      "get": {
        "tags": ["Routes"],
        "summary": "Get route by slug",
        "security": [],
        "parameters": [
          { "name": "slug", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Route details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "$ref": "#/components/schemas/Route" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/routes/{slug}/estimate": {
      "get": {
        "tags": ["Routes"],
        "summary": "Get cost estimate for route",
        "security": [],
        "parameters": [
          { "name": "slug", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "vehicle", "in": "query", "schema": { "type": "string", "enum": ["mobil", "motor", "suv", "mpv"] } }
        ],
        "responses": {
          "200": {
            "description": "Cost estimate",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "distanceKm": { "type": "number" },
                        "fuelCost": { "type": "integer" },
                        "fuelLiters": { "type": "number" },
                        "totalCost": { "type": "integer" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/waitlist": {
      "post": {
        "tags": ["Waitlist"],
        "summary": "Add email to waitlist",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "source": { "type": "string", "default": "website" }
                }
              },
              "example": {
                "email": "user@example.com",
                "source": "website"
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Email registered" },
          "409": { "description": "Email already registered" }
        }
      },
      "get": {
        "tags": ["Waitlist"],
        "summary": "List waitlist entries",
        "security": [{ "cookieAuth": [] }]
      }
    },
    "/waitlist/export": {
      "get": {
        "tags": ["Waitlist"],
        "summary": "Export waitlist as CSV",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": {
            "description": "CSV file download",
            "content": { "text/csv": { "schema": { "type": "string" } } }
          }
        }
      }
    },
    "/analytics/views": {
      "get": {
        "tags": ["Analytics"],
        "summary": "Get page view statistics",
        "security": [{ "cookieAuth": [] }]
      }
    },
    "/analytics/spots": {
      "get": {
        "tags": ["Analytics"],
        "summary": "Get spot view statistics",
        "security": [{ "cookieAuth": [] }]
      }
    },
    "/analytics/categories": {
      "get": {
        "tags": ["Analytics"],
        "summary": "Get category distribution",
        "security": [{ "cookieAuth": [] }]
      }
    },
    "/analytics/daily": {
      "get": {
        "tags": ["Analytics"],
        "summary": "Get daily page views",
        "security": [{ "cookieAuth": [] }]
      }
    },
    "/analytics/track": {
      "post": {
        "tags": ["Analytics"],
        "summary": "Track analytics event",
        "security": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "eventType": { "type": "string" },
                  "entityType": { "type": "string" },
                  "entityId": { "type": "string" },
                  "metadata": { "type": "object" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Event tracked" } }
      }
    },
    "/upload/spot": {
      "post": {
        "tags": ["Upload"],
        "summary": "Upload spot image",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": { "type": "string", "format": "binary" },
                  "credit": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Image uploaded",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "url": { "type": "string" },
                    "key": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/upload/product": {
      "post": {
        "tags": ["Upload"],
        "summary": "Upload product image",
        "security": [{ "cookieAuth": [] }]
      }
    },
    "/upload/presign": {
      "post": {
        "tags": ["Upload"],
        "summary": "Get presigned URL for direct upload",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "fileName": { "type": "string" },
                  "folder": { "type": "string" },
                  "contentType": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Presigned URL",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "uploadUrl": { "type": "string" },
                    "key": { "type": "string" },
                    "publicUrl": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "sb-{project-ref}-auth-token",
        "description": "Supabase Auth session cookie"
      }
    },
    "schemas": {
      "APIError": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": { "type": "string" },
              "message": { "type": "string" },
              "details": { "type": "object" }
            }
          }
        }
      },
      "Pagination": {
        "type": "object",
        "properties": {
          "total": { "type": "integer" },
          "limit": { "type": "integer" },
          "offset": { "type": "integer" },
          "hasMore": { "type": "boolean" }
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "user": { "$ref": "#/components/schemas/UserProfile" },
          "session": {
            "type": "object",
            "properties": {
              "access_token": { "type": "string" },
              "refresh_token": { "type": "string" },
              "expires_at": { "type": "integer" }
            }
          }
        }
      },
      "UserProfile": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "email": { "type": "string" },
          "fullName": { "type": "string" },
          "avatarUrl": { "type": "string" },
          "role": { "type": "string", "enum": ["user", "super_admin"] },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "GeoPoint": {
        "type": "object",
        "properties": {
          "lat": { "type": "number" },
          "lng": { "type": "number" }
        }
      },
      "Spot": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "slug": { "type": "string" },
          "name": { "type": "string" },
          "category": { "type": "string", "enum": ["alam", "kuliner", "budaya", "foto", "petualangan", "sejarah"] },
          "province": { "type": "string" },
          "region": { "type": "string" },
          "location": { "$ref": "#/components/schemas/GeoPoint" },
          "description": { "type": "string" },
          "whySpecial": { "type": "string" },
          "rating": { "type": "number" },
          "imageUrl": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "tips": { "type": "string" },
          "bestTime": { "type": "string" },
          "openingHours": { "type": "string" },
          "estimatedTime": { "type": "string" },
          "ticketPrice": { "type": "string" },
          "roadAccess": { "type": "string" },
          "facilities": { "type": "array", "items": { "type": "string" } },
          "distanceFromCity": { "type": "string" },
          "isFeatured": { "type": "boolean" },
          "viewCount": { "type": "integer" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "CreateSpotInput": {
        "type": "object",
        "required": ["name", "category", "province", "region", "location", "description"],
        "properties": {
          "name": { "type": "string" },
          "category": { "type": "string" },
          "province": { "type": "string" },
          "region": { "type": "string" },
          "location": { "$ref": "#/components/schemas/GeoPoint" },
          "description": { "type": "string" },
          "whySpecial": { "type": "string" },
          "rating": { "type": "number" },
          "imageUrl": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "tips": { "type": "string" },
          "bestTime": { "type": "string" },
          "openingHours": { "type": "string" },
          "estimatedTime": { "type": "string" },
          "ticketPrice": { "type": "string" },
          "roadAccess": { "type": "string" },
          "facilities": { "type": "array", "items": { "type": "string" } },
          "distanceFromCity": { "type": "string" },
          "isFeatured": { "type": "boolean" }
        }
      },
      "UpdateSpotInput": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "category": { "type": "string" },
          "province": { "type": "string" },
          "region": { "type": "string" },
          "location": { "$ref": "#/components/schemas/GeoPoint" },
          "description": { "type": "string" },
          "whySpecial": { "type": "string" },
          "rating": { "type": "number" },
          "imageUrl": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "tips": { "type": "string" },
          "isFeatured": { "type": "boolean" }
        }
      },
      "Product": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "slug": { "type": "string" },
          "name": { "type": "string" },
          "category": { "type": "string" },
          "price": { "type": "integer" },
          "originalPrice": { "type": "integer" },
          "description": { "type": "string" },
          "imageUrl": { "type": "string" },
          "rating": { "type": "number" },
          "stockQuantity": { "type": "integer" },
          "isFeatured": { "type": "boolean" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "CreateProductInput": {
        "type": "object",
        "required": ["name", "category", "price"],
        "properties": {
          "name": { "type": "string" },
          "category": { "type": "string" },
          "price": { "type": "integer" },
          "originalPrice": { "type": "integer" },
          "description": { "type": "string" },
          "imageUrl": { "type": "string" },
          "stockQuantity": { "type": "integer" }
        }
      },
      "POI": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "category": { "type": "string", "enum": ["spbu", "kuliner", "bengkel", "spot_foto", "info_jalan"] },
          "location": { "$ref": "#/components/schemas/GeoPoint" },
          "address": { "type": "string" },
          "rating": { "type": "number" },
          "verified": { "type": "boolean" },
          "imageUrl": { "type": "string" },
          "description": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "Route": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "slug": { "type": "string" },
          "name": { "type": "string" },
          "origin": { "type": "string" },
          "destination": { "type": "string" },
          "distanceKm": { "type": "number" },
          "durationHours": { "type": "number" },
          "polyline": { "type": "array", "items": { "$ref": "#/components/schemas/GeoPoint" } },
          "poiIds": { "type": "array", "items": { "type": "string" } },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}
